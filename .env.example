# ════════════════════════════════════════════════════════════════════
#  Find me in the terminal — Environment Variables
#  Copy this file to .env and fill in every value
# ════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────
APP_NAME="Find me in the terminal"
APP_URL="https://yourdomain.com"           # no trailing slash
DEBUG=false

# ── Neon PostgreSQL ──────────────────────────────────────────────────
# Get this from: console.neon.tech → your project → Connection string
# IMPORTANT: replace 'postgresql://' with 'postgresql+asyncpg://'
# and add '?sslmode=require' at the end
DATABASE_URL="postgresql+asyncpg://user:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── SMTP (Gmail recommended) ─────────────────────────────────────────
# Step 1: Enable 2-Factor Authentication on your Google account
# Step 2: Go to myaccount.google.com/apppasswords
# Step 3: Create an App Password → copy the 16-character code
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@gmail.com"
SMTP_PASSWORD="xxxx xxxx xxxx xxxx"        # 16-char Gmail App Password
FROM_NAME="Find me in the terminal"
FROM_EMAIL="your@gmail.com"

# ── Security ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY="change-me-generate-with-openssl-rand-hex-32"
UNSUBSCRIBE_SALT="change-me-also-random"
